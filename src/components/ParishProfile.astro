---
import { Image } from 'astro:assets';
const { name, img, priest, vicar, address, mapUrl, contact, fbLink,
 weekdaySchedule, satSchedule, sunAM, sunPM,
   confessionSchedule, officeHours } = Astro.props;
---

<section class="parish-profile-container">
  <div class="hero-image-wrapper">
    <Image src={img} alt={name} class="wide-photo" />
    <div class="image-inner-shadow"></div>
  </div>

  <div class="profile-body">
    {/* Title Section */}
    <header class="profile-header">
      <h2 class="parish-name">{name}</h2>
      <div class="accent-bar"></div>
    </header>

    {/* Information Grid */}
    <div class="info-grid">
      <div class="info-column">
          {/*  Parish Priest */}
          <div class="info-item">
            <span class="label">Parish Priest</span>
            <p class="value">{priest}</p>
          </div>
          {/*  Parochial Vicar */}
          <div class="info-item">
            <span class="label">Parochial Vicar</span>
            <p class="value">
              {vicar ? (
                vicar
              ) : (
                <span class="placeholder-text">To be added</span>
              )}
            </p>
          </div>
          {/*  Contact Information */}
          <div class="info-item">
            <span class="label">Contact</span>
            <p class="value">{contact}</p>
          </div>
          {/* Facebook Page Link */}
          <div class="info-item action-item">
            <p class="value">
              <a href={fbLink} target="_blank" class="gold-link">
                View Official Facebook Page →
              </a>
            </p>
          </div>
      </div>
      {/* Address and Map Link */}
      <div class="info-column">
          <div class="info-item">
            <span class="label">Location</span>
            <p class="value">{address}</p>
            {mapUrl && (
              <div class="map-wrapper">
                <iframe src={mapUrl} width="100%" height="200" style="border:0;" allowfullscreen="" loading="lazy"></iframe>
              </div>
            )}
          </div>
          
          
        </div>
    </div>

    {/* History Section */}
    <div class="narrative-section">
      <h3>Our Heritage</h3>
      <div class="history-content">
        <slot />
      </div>
    </div>

    {/* Schedule Section */}
    <div class="schedule-section">
      <div class="schedule-divider"></div>
      
      <div class="schedule-header">
        <h3>Church Schedules</h3>
      </div>

      <div class="schedule-container">
        <div class="schedule-group">
          <div class="schedule-badge">Weekdays</div>
          <p class="schedule-value">{weekdaySchedule}</p>
        </div>

        <div class="schedule-group">
          <div class="schedule-badge">Saturday</div>
          <p class="schedule-value">{satSchedule}</p>
        </div>

        <div class="schedule-group sunday-group">
          <div class="schedule-badge">Sunday</div>
          <div class="sunday-columns-wrapper">
            <div class="column">
              <p class="schedule-value">{sunAM}</p>
            </div>
            <div class="column-divider"></div>
            <div class="column">
              <p class="schedule-value">{sunPM}</p>
            </div>
          </div>
        </div>

        {/* Confession Group (Optional) */}
        <div class="schedule-group">
          <div class="schedule-badge">Confession Hours</div>
          <p class={confessionSchedule ? "schedule-value" : "placeholder-text"}>
            {confessionSchedule ? confessionSchedule : "To be added"}
          </p>
        </div>

        {/* Office Hours Group (Optional) */}
        <div class="schedule-group">
          <div class="schedule-badge">Parish Office</div>
          <p class={officeHours ? "schedule-value" : "placeholder-text"}>
            {officeHours ? officeHours : "To be added"}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .parish-profile-container {
    background-color: var(--sl-color-gray-6);
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 16px;
    overflow: hidden;
    margin: 3rem 0;
    box-shadow: var(--sl-shadow-md);
  }

  .hero-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 21 / 9;
    overflow: hidden;
  }

  .wide-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: brightness(0.7) saturate(0.7); 
    transition: 
      transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), 
      filter 0.6s ease;
  }

  .parish-profile-container:hover .wide-photo {
    transform: scale(1.1);
    filter: brightness(0.9) saturate(0.9);
  }

  .image-inner-shadow {
    position: absolute;
    inset: 0;
    box-shadow: inset 0 -40px 60px rgba(0, 0, 0, 0.2);
  }

  .profile-body {
    padding: 3rem;
  }

  .placeholder-text {
    font-style: italic;
    opacity: 0.7; 
    font-size: 1.05rem;
  }

  .parish-name {
    font-family: 'Playfair Display', serif;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--sl-color-white);
    margin: 0;
    line-height: 1.2;
  }

  .accent-bar {
    width: 80px;
    height: 3px;
    background: #d4af37; 
    margin: 1.5rem 0 2.5rem;
  }

  .info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr; 
    gap: 3rem; 
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    padding-bottom: 2rem;
    align-items: start; 
  }

  .info-item {
    margin: 0 !important; 
  }

  .info-column {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    margin: 0;
    padding: 0;
    gap: 2rem;
    height: auto;
  }

  .info-item:first-child {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  .info-column > .info-item:first-child {
    margin-top: 0 !important;
  }

  .info-item:first-child {
    flex: 1; 
    margin-bottom: 2rem;
  }

  .label {
    display: block;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #d4af37;
    margin: 0 0 0.2rem 0; 
    font-weight: 700;
    line-height: 1.2;
  }

  .value {
    font-size: 1.05rem;
    color: var(--sl-color-gray-2);
    margin: 0 !important; 
    line-height: 1.4;
    padding-top: 0.25rem; 
  }

  .gold-link {
    color: #d4af37;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.95rem;
    transition: opacity 0.2s;
  }

  .gold-link:hover {
    opacity: 0.8;
    text-decoration: underline;
  }

  /* Text Area */
  .narrative-section h3 {
    border-left: 4px solid #d4af37; 
    padding-left: 1rem;
    color: var(--sl-color-white);
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .history-content {
    line-height: 1.8;
    color: var(--sl-color-gray-3);
    text-align: justify;
  }

  .schedule-section {
    margin-top: 3rem;
  }

  .schedule-divider {
    height: 1px;
    background: var(--sl-color-gray-5);
    margin-bottom: 2rem;
  }

  .schedule-header {
    border-left: 4px solid #d4af37; 
    padding-left: 1rem;
    margin-bottom: 2.5rem !important;
  }

  .schedule-header h3 {
    letter-spacing: 0.05em;
    font-size: 1.5rem;
    color: var(--sl-color-white);
  }

  .schedule-container {
    display: flex;
    flex-wrap: wrap;
    gap: 2rem;
  }

  .schedule-group {
    flex: 1;
    margin-top: 0 !important;
    min-width: 250px;
    max-width: 50%; 
  }

  .sunday-group {
    flex: 1;
    min-width: 250px;
    max-width: 50%; 
  }

  .sunday-columns-wrapper {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    justify-self: flex-start;
  }

  .sunday-columns-wrapper .column {
    flex: 0 1 auto;
    margin: 0;
    padding: 0;
    min-width: 10%;
  }

  .column-divider {
    width: 1px;
    background-color: var(--sl-color-gray-5);
    align-self: stretch; 
    margin: 0.5rem 0;
  }

  .schedule-badge {
  color:#d4af37;
  font-size: 1rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 1rem;
  box-shadow: 0 0px 10px rgba(0,0,0,0);
}

.schedule-value {
  margin-top: 0 !important;
  padding-top: 0 !important;
  font-weight: 400;
  letter-spacing: 0.02em;
  color: var(--sl-color-gray-3);
  white-space: pre-line;
}

.map-wrapper {
    margin-top: 1rem;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--sl-color-gray-5);
    filter: grayscale(0.5) contrast(1.1); /* Optional: matches a darker theme better */
    transition: filter 0.3s ease;
}

.map-wrapper:hover {
    filter: grayscale(0);
}

.map-wrapper iframe {
    display: block;
}

@media (max-width: 768px) {
    .hero-image-wrapper { aspect-ratio: 16 / 9; }
    .info-grid { grid-template-columns: 1fr; gap: 2rem; }
    .profile-body { padding: 1.5rem; }
    .schedule-container { flex-direction: column; }
    .schedule-group { width: 100%; }
    .map-wrapper { height: 180px; }
    .column-divider {display: none;}
    .sunday-columns-wrapper {flex-direction: column; gap: 1rem;}

  }

</style>